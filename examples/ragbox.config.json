{
  "version": 1,
  "pageIndex": {
    "cli": "/path/to/PageIndex/run_pageindex.py",
    "concurrency": 1
  },
  "llm": {
    "baseUrl": "https://api.openai.com/v1",
    "model": "gpt-4o-mini"
  },
  "serve": {
    "authToken": "YOUR_RAGBOX_SERVE_TOKEN",
    "host": "127.0.0.1",
    "port": 8787
  },
  "sources": {
    "ragbox": {
      "rootDir": "./ragbox",
      "outputDir": "./.ragbox-index/ragbox",
      "include": ["**/*.md", "**/*.mdx"]
    },
    "icharts": {
      "rootDir": "./icharts",
      "outputDir": "./.ragbox-index/icharts",
      "include": ["**/*.md", "**/*.mdx"]
    }
  }
}
