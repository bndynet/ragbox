RAGBOX_E2E=1
RAGBOX_VERBOSE=1
# Relative paths are resolved from the ragbox repo root.
PAGEINDEX_CLI=../PageIndex/run_pageindex.py
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1
PAGEINDEX_MODEL=gpt-4o-mini
RAGBOX_E2E_QUERY_MODEL=gpt-4o-mini
RAGBOX_E2E_DOCS_DIR=./examples
RAGBOX_E2E_OUTPUT_DIR=./examples/.pageindex
RAGBOX_E2E_EXPECTED_TEXT=PKCE

# Optional, if your PageIndex CLI supports an explicit output path flag:
# PAGEINDEX_OUTPUT_ARG=--output

# Optional, pass additional arguments to PageIndex:
# PAGEINDEX_EXTRA_ARGS=--if-add-node-summary yes

# Optional, equivalent to passing --pageindex-python during the e2e index command:
# RAGBOX_E2E_PAGEINDEX_PYTHON=/path/to/python

# Optional:
# RAGBOX_E2E_TIMEOUT_MS=900000
# RAGBOX_E2E_COMMAND_TIMEOUT_MS=300000
# RAGBOX_E2E_HEARTBEAT_MS=10000
# RAGBOX_E2E_QUESTION=What problem does PKCE solve in OAuth 2.0, and how does it reduce authorization code interception risk? Cite the source.
